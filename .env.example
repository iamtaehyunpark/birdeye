# ─── BirdEye Configuration ────────────────────────────────────────────────────

# Path to YOLO model weights (.pt file)
# Defaults to yolov8n.pt (auto-downloaded by ultralytics on first run)
# Point this to your own trained model:
MODEL_PATH=yolov8n.pt

# Detection confidence threshold (0.0–1.0)
CONF_THRESHOLD=0.35

# Server bind settings
HOST=0.0.0.0
PORT=8000

# Kalman tracker settings
TRACKER_MAX_AGE_SEC=2.0
TRACKER_MAX_DIST=150.0
TRACKER_MIN_HITS=2

# Background differencing (0–255): pixel diff magnitude above which a pixel
# is considered foreground (= not in the reference image).
# Lower → more sensitive (may pick up lighting noise)
# Higher → less sensitive (may miss slow/small objects)
BG_DIFF_THRESHOLD=40
